{
  "name": "devkit-console-core",
  "version": "0.1.0",
  "description": "Zero-deps debug manager for browser console + storage",
  "author": "ikrigel <ikrigel@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikrigel/devkit-console.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ikrigel/devkit-console/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/ikrigel/devkit-console/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest",
    "test:run": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "keywords": ["debug", "logging", "devtools"],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "jsdom": "^22.1.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  }
}
